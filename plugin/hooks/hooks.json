{
  "hooks": {
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m aiteam.hooks.inject_subagent_context",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python -m aiteam.hooks.send_event SubagentStart",
            "timeout": 2000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m aiteam.hooks.send_event SubagentStop",
            "timeout": 2000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent|Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python -m aiteam.hooks.workflow_reminder PreToolUse",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python -m aiteam.hooks.send_event PreToolUse",
            "timeout": 2000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent|Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python -m aiteam.hooks.workflow_reminder PostToolUse",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python -m aiteam.hooks.send_event PostToolUse",
            "timeout": 2000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m aiteam.hooks.session_bootstrap",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python -m aiteam.hooks.send_event SessionStart",
            "timeout": 2000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m aiteam.hooks.send_event SessionEnd",
            "timeout": 2000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m aiteam.hooks.send_event Stop",
            "timeout": 2000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m aiteam.hooks.context_monitor",
            "timeout": 3000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m aiteam.hooks.pre_compact_save",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
